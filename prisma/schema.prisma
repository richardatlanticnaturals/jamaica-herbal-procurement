generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// AUTH (NextAuth)
// ============================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// CORE BUSINESS MODELS
// ============================================

model Vendor {
  id              String      @id @default(cuid())
  comcashVendorId String?     @unique
  name            String
  contactName     String?
  email           String?
  phone           String?
  website         String?
  orderMethod    OrderMethod @default(EMAIL)
  portalUrl      String?
  portalUsername String?
  portalPassword String?
  emailTemplate  String?     @db.Text
  leadTimeDays   Int         @default(3)
  minimumOrder   Decimal?    @db.Decimal(10, 2)
  paymentTerms   String?
  notes          String?     @db.Text
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  items          InventoryItem[]
  purchaseOrders PurchaseOrder[]
  alternatives   AlternativeProduct[]
}

model InventoryItem {
  id               String   @id @default(cuid())
  shopifyProductId String?
  shopifyVariantId String?
  comcashItemId    String?
  sku              String   @unique
  name             String
  vendorId         String?
  vendor           Vendor?  @relation(fields: [vendorId], references: [id])
  vendorSku        String?
  costPrice        Decimal  @default(0) @db.Decimal(10, 2)
  retailPrice      Decimal  @default(0) @db.Decimal(10, 2)
  currentStock     Int      @default(0)
  reorderPoint     Int      @default(5)
  reorderQty       Int      @default(12)
  locationLL       Int      @default(0)
  locationNL       Int      @default(0)
  category         String?
  unitOfMeasure    String   @default("each")
  isActive         Boolean  @default(true)
  lastSyncedAt     DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  poLineItems    POLineItem[]
  receivingItems ReceivingLineItem[]
  alternatives   AlternativeProduct[] @relation("PrimaryItem")
  productSales   ProductSales[]
}

model PurchaseOrder {
  id             String      @id @default(cuid())
  poNumber       String      @unique
  vendorId       String
  vendor         Vendor      @relation(fields: [vendorId], references: [id])
  status         POStatus    @default(DRAFT)
  subtotal       Decimal     @default(0) @db.Decimal(10, 2)
  tax            Decimal     @default(0) @db.Decimal(10, 2)
  shipping       Decimal     @default(0) @db.Decimal(10, 2)
  total          Decimal     @default(0) @db.Decimal(10, 2)
  locationCode   String?
  notes          String?     @db.Text
  orderMethod    OrderMethod @default(EMAIL)
  sentAt         DateTime?
  expectedDate   DateTime?
  receivedAt     DateTime?
  createdBy      String      @default("system")
  emailMessageId String?
  confirmationId String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  lineItems     POLineItem[]
  receivings    Receiving[]
  statusHistory POStatusLog[]
}

model POLineItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  vendorSku       String?
  description     String
  qtyOrdered      Int
  qtyReceived     Int           @default(0)
  unitCost        Decimal       @db.Decimal(10, 2)
  lineTotal       Decimal       @db.Decimal(10, 2)
  isOutOfStock    Boolean       @default(false)
  outOfStockNote  String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Receiving {
  id              String      @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  receivedDate    DateTime    @default(now())
  receivedBy      String?
  invoiceNumber   String?
  invoiceImageUrl String?
  ocrRawText      String?     @db.Text
  ocrParsedData   Json?
  matchStatus     MatchStatus @default(PENDING)
  notes           String?     @db.Text
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  lineItems ReceivingLineItem[]
}

model ReceivingLineItem {
  id              String         @id @default(cuid())
  receivingId     String
  receiving       Receiving      @relation(fields: [receivingId], references: [id], onDelete: Cascade)
  inventoryItemId String?
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  ocrDescription  String
  ocrQty          Int
  ocrUnitCost     Decimal?       @db.Decimal(10, 2)
  matchedToPoLine Boolean        @default(false)
  matchConfidence Float?
  qtyAccepted     Int            @default(0)
  notes           String?
}

model AlternativeProduct {
  id            String         @id @default(cuid())
  primaryItemId String
  primaryItem   InventoryItem  @relation("PrimaryItem", fields: [primaryItemId], references: [id])
  altVendorId   String?
  altVendor     Vendor?        @relation(fields: [altVendorId], references: [id])
  altItemName   String
  altSku        String?
  altCostPrice  Decimal?       @db.Decimal(10, 2)
  reason        String?        @db.Text
  score         Float?
  createdAt     DateTime       @default(now())
}

model POStatusLog {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  fromStatus      POStatus?
  toStatus        POStatus
  note            String?
  triggeredBy     String        @default("system")
  createdAt       DateTime      @default(now())
}

model AppSettings {
  id                  String   @id @default("singleton")
  comcashApiUrl       String?
  comcashApiKey       String?
  gmailRefreshToken   String?
  autoGeneratePOs     Boolean  @default(false)
  autoSendPOs         Boolean  @default(false)
  poApprovalRequired  Boolean  @default(true)
  defaultLeadTimeDays Int      @default(3)
  poNumberPrefix      String   @default("PO")
  nextPoSequence      Int      @default(1)
  syncIntervalMinutes Int      @default(60)
  lastInventorySync   DateTime?
  lastVendorSync      DateTime?
  lastProductSync     DateTime?
  lastStockSync       DateTime?
  lastSalesSync       DateTime?
  defaultReorderPoint Int      @default(5)
  defaultReorderQty   Int      @default(12)
}

// ============================================
// SALES CACHE (aggregated from Comcash sale/list API)
// ============================================

model ProductSales {
  id              String   @id @default(cuid())
  sku             String
  comcashProductId Int?
  productName     String
  totalQtySold    Int      @default(0)
  totalRevenue    Decimal  @default(0) @db.Decimal(10, 2)
  lastSoldAt      DateTime?
  salesCount      Int      @default(0)
  periodStart     DateTime
  periodEnd       DateTime
  inventoryItemId String?
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([sku, periodStart])
}

// ============================================
// ENUMS
// ============================================

enum OrderMethod {
  EMAIL
  PORTAL
  PHONE
  API
}

enum POStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENT
  CONFIRMED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
  CLOSED
}

enum MatchStatus {
  PENDING
  MATCHED
  PARTIAL_MATCH
  MISMATCH
  MANUAL_REVIEW
}
